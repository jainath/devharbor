<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      DevHarbor runs user-supplied dev scripts via PTY. We need:
      - allow-jit + allow-unsigned-executable-memory for V8 / native modules
      - allow-dyld-environment-variables so we can prepend the resolved Node bin dir to PATH for children
      - Files-User-Selected (read/write) so the user can browse to / read project folders
      - inherit because spawned child processes inherit these capabilities
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!--
      disable-library-validation is retained because better-sqlite3 / node-pty / pidusage ship
      as upstream prebuilt binaries not signed by this Team ID. (disable-executable-page-protection
      was removed — IMPROVEMENT-PLAN 6.3 — as the most permissive of the set and unneeded once
      allow-jit + allow-unsigned-executable-memory are present; re-add only if a notarized build
      fails to launch.)
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.inherit</key>
    <true/>
  </dict>
</plist>
